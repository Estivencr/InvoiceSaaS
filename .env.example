# PostgreSQL Configuration
DB_USER=invoiceuser
DB_PASSWORD=SecurePassword123!
DB_NAME=invoice_saas_db

# JWT Configuration
JWT_SECRET=YourSuperSecretKeyWith32CharactersMinimum!
